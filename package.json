{
  "name": "xevn-ecosystem",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=./apps/*",
    "dev:all": "turbo run dev",
    "dev:x-bos": "turbo run dev --filter=x-bos",
    "dev:ui": "turbo run dev --filter=@xevn/ui",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "eslint": "^8.57.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "turbo": "^2.0.0"
  }
}
